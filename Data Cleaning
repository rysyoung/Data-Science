import numpy as np
import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

######### read in CSV file and Assign it to a Dataframe ####################
df= pd.DataFrame
df = pd.read_excel('/content/Generic Inventory.xlsx')
#print(df)

############## Clean the Data ###############

df.columns = [c.strip().replace(' ', '_').title() for c in df.columns]
df['Description'] = df['Description'].astype(str).str.strip().str.title()
df['Status'] = df['Status'].astype(str).str.strip().str.upper()
df['Calibration'] = df['Calibration'].astype(str).str.strip().str.upper().replace('N', False).replace('Y', True)
df['Installation_Date'] = pd.to_datetime(df['Installation_Date'])
df['Asset_Age_Days'] = (pd.Timestamp.now() - df['Installation_Date']).dt.days
df.drop_duplicates(subset=['Asset'], inplace=True)
df.fillna(0, inplace=True)
df = df.reset_index(drop=True)
print(df.columns.tolist())
print(df.shape)
print(df.head(10))

