  first_csv_col1 = []
  first_csv_col2 = []
  first_csv_col3 = []

  second_csv_col1 = []
  second_csv_col2 = []
  second_csv_col3 = []

  for i in range(len(array_1st_csv)):
    if i % 3 == 0:
      first_csv_col1.append(array_1st_csv[i])
    elif i % 3 == 1:
      first_csv_col2.append(array_1st_csv[i])
    elif i % 3 == 2:
      first_csv_col3.append(array_1st_csv[i])

  for i in range(len(array_2nd_csv)):
    if i % 3 == 0:
      second_csv_col1.append(array_2nd_csv[i])
    elif i % 3 == 1:
      second_csv_col2.append(array_2nd_csv[i])
    elif i % 3 == 2:
      second_csv_col3.append(array_2nd_csv[i])

  # Determine the minimum length among the three first CSV columns
  min_len_first_csv_cols = min(len(first_csv_col1), len(first_csv_col2), len(first_csv_col3))
  # Determine the minimum length among the three second CSV columns
  min_len_second_csv_cols = min(len(second_csv_col1), len(second_csv_col2), len(second_csv_col3))

  for i in range(min_len_first_csv_cols):
    compared_col1_1st_csv = str(first_csv_col1[i])
    compared_col2_1st_csv = str(first_csv_col2[i])
    compared_col3_1st_csv = str(first_csv_col3[i])

    for j in range(min_len_second_csv_cols):
      compared_col1_2nd_csv = str(second_csv_col1[j])
      compared_col2_2nd_csv = str(second_csv_col2[j])
      compared_col3_2nd_csv = str(second_csv_col3[j])

      dp_col1 = [[0]*(len(compared_col1_2nd_csv)+1)for _ in range(len(compared_col1_1st_csv)+1)]
      dp_col2 = [[0]*(len(compared_col2_2nd_csv)+1)for _ in range(len(compared_col2_1st_csv)+1)]
      dp_col3 = [[0]*(len(compared_col3_2nd_csv)+1)for _ in range(len(compared_col3_1st_csv)+1)]

      for ii in range(len(compared_col1_1st_csv) + 1):
        dp_col1[ii][0] = ii #cost of deletions
