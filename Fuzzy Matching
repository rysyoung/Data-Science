      for ii in range(1, len(compared_col1_1st_csv) + 1):
        for jj in range(1, len(compared_col1_2nd_csv)+1):
          if compared_col1_1st_csv[ii-1] == compared_col1_2nd_csv[jj-1]:
            cost = 0
          else:
            cost = 1

          dp_col1[ii][jj] = min(
                dp_col1[ii - 1][jj] + 1,      # deletion
