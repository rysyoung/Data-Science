############ This Function Reads the first csv file and breaks it into a list based on lines in the file ###############
def first_csv():
  file = open('/content/E-Systems Physical Inventory.csv', 'r')
  values = file.readlines()
  global first_csv_values
  first_csv_values = []
  for line in values:
    # Strip the entire line first to remove newline and other leading/trailing whitespace
    cleaned_line = line.strip()
    processing_array = cleaned_line.split(',')
    for item in processing_array:
      # Additionally strip each item just in case of spaces around commas
      first_csv_values.append(item.strip())
  #print(len(first_csv_values))
  # These pops assume the first 3 elements are headers for 3 columns.
  # This is a bit fragile if the number of header elements doesn't match the column count.
  first_csv_values.pop(0)
  first_csv_values.pop(0)
  first_csv_values.pop(0)
first_csv()
